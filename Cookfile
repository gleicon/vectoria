#!/usr/bin/env python3
"""
Vectoria deployment — Cook configuration
https://github.com/gleicon/cook

Usage:
  cook plan  Cookfile      # dry-run: show what would change
  cook apply Cookfile      # apply changes to remote server
  cook state Cookfile      # show current remote state

Fallback (cook not installed):
  ./deploy/setup.sh        # first-time
  ./deploy/deploy.sh       # incremental
"""

from cook import Plan, File, Exec, Service, Package

APP_DIR = "/opt/apps/vectoria"
ALGOLIA_REPO = "https://github.com/gleicon/vectoria-algolia.git"

plan = Plan(
    name="vectoria",
    host="169.150.1.130",
    user="ubuntu",
    key="~/.ssh/id_rsa_mgc_saas_apps",
)

# ── Directory structure ────────────────────────────────────────────────────
Exec(
    f"mkdir -p {APP_DIR}/{{website,webstore,deploy/nginx,data,logs}}",
    plan=plan,
    sudo=True,
    name="create-dirs",
)

# ── nginx configuration ────────────────────────────────────────────────────
File(
    path="/etc/nginx/sites-available/vectoriasearch.com",
    src="deploy/nginx/vectoriasearch.com",
    plan=plan,
    sudo=True,
    name="nginx-config",
)

Exec(
    "ln -sf /etc/nginx/sites-available/vectoriasearch.com "
    "/etc/nginx/sites-enabled/vectoriasearch.com",
    plan=plan,
    sudo=True,
    name="nginx-enable",
)

# ── nginx service ──────────────────────────────────────────────────────────
Service(
    name="nginx",
    action="reload",
    plan=plan,
    sudo=True,
)

# ── Full repo sync (source required for docker build) ─────────────────────
# Excludes build cache, git history, secrets, and server-managed dirs that
# must NOT be deleted by --delete (webstore/website are synced separately below).
Exec(
    f"rsync -az --checksum --delete "
    f"  --exclude='.git/' --exclude='target/' --exclude='.claude/' "
    f"  --exclude='deploy/.env' --exclude='*.env' "
    f"  --exclude='webstore/' --exclude='website/' "
    f"  --exclude='data/' --exclude='logs/' --exclude='vectoria-algolia/' "
    f"  -e 'ssh -i ~/.ssh/id_rsa_mgc_saas_apps -o StrictHostKeyChecking=no' "
    f"  ./ ubuntu@169.150.1.130:{APP_DIR}/",
    plan=plan,
    name="source-sync",
)

Exec(
    f"rsync -az --checksum --delete "
    f"  -e 'ssh -i ~/.ssh/id_rsa_mgc_saas_apps -o StrictHostKeyChecking=no' "
    f"  website/ ubuntu@169.150.1.130:{APP_DIR}/website/",
    plan=plan,
    name="website-sync",
)

Exec(
    f"rsync -az --checksum --delete "
    f"  -e 'ssh -i ~/.ssh/id_rsa_mgc_saas_apps -o StrictHostKeyChecking=no' "
    f"  examples/webstore/ ubuntu@169.150.1.130:{APP_DIR}/webstore/",
    plan=plan,
    name="webstore-sync",
)

# ── vectoria-algolia clone ─────────────────────────────────────────────────
Exec(
    f"test -d {APP_DIR}/vectoria-algolia/.git "
    f"  && git -C {APP_DIR}/vectoria-algolia pull --ff-only "
    f"  || git clone {ALGOLIA_REPO} {APP_DIR}/vectoria-algolia",
    plan=plan,
    name="algolia-repo",
)

# ── vectoria-server (Docker Compose) ──────────────────────────────────────
Exec(
    f"cd {APP_DIR} && "
    "sudo docker compose -f deploy/docker-compose.prod.yml --env-file .env "
    "up -d --build --remove-orphans",
    plan=plan,
    name="vectoria-server",
)

# ── vectoria-algolia (Docker Compose with port override) ──────────────────
Exec(
    f"cd {APP_DIR}/vectoria-algolia && "
    "sudo docker compose "
    f"-f docker-compose.yml "
    f"-f {APP_DIR}/deploy/docker-compose.algolia-override.yml "
    "up -d --build --remove-orphans search loader",
    plan=plan,
    name="vectoria-algolia",
)

# ── Webstore config.js (inject API key from .env) ─────────────────────────
Exec(
    f"VECTORIA_API_KEY=$(grep ^VECTORIA_API_KEY {APP_DIR}/.env | cut -d= -f2 | tr -d '\"') && "
    f"echo \"window.VECTORIA_API_KEY = '${{VECTORIA_API_KEY}}';\" > {APP_DIR}/webstore/config.js",
    plan=plan,
    name="webstore-config",
)

# ── Load demo products into vectoria-server ────────────────────────────────
# Reads batch.json from vectoria-algolia (same product set) and POSTs to /products.
# Safe to re-run — vectoria-server upserts on id.
Exec(
    f"python3 - <<'PYEOF'\n"
    f"import json, urllib.request, urllib.error\n"
    f"with open('{APP_DIR}/vectoria-algolia/scripts/batch.json') as f: data = json.load(f)\n"
    f"SERVER = 'http://127.0.0.1:7700'\n"
    f"API_KEY = next((l.split('=',1)[1].strip().strip('\"') for l in open('{APP_DIR}/.env').read().splitlines() if l.startswith('VECTORIA_API_KEY')), 'vectoria-demo')\n"
    f"ok = 0\n"
    f"for req in data['requests']:\n"
    f"    body = req['body']\n"
    f"    text = ' '.join(filter(None, [body.get('title',''), body.get('brand',''), body.get('category',''), body.get('description','')]))\n"
    f"    product = json.dumps({{'id': body['objectID'], 'text': text, 'metadata': body}}).encode()\n"
    f"    r = urllib.request.Request(f'{{SERVER}}/products', data=product, headers={{'Content-Type': 'application/json', 'Authorization': f'Bearer {{API_KEY}}'}}, method='POST')\n"
    f"    try: urllib.request.urlopen(r); ok += 1\n"
    f"    except: pass\n"
    f"print(f'{{ok}} products indexed into vectoria-server.')\n"
    f"PYEOF",
    plan=plan,
    name="load-products",
)
